# Database — SQLite is default, switch to Postgres in production
DATABASE_URL="file:./dev.db"

# NextAuth — generate with: openssl rand -hex 32
AUTH_SECRET=your-secret-key-here

# Google OAuth (optional) — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# App URL — used for email links and callbacks
AUTH_URL=http://localhost:3000

# Resend (email) — https://resend.com/api-keys
RESEND_API_KEY=

# From address for transactional emails
EMAIL_FROM=noreply@vajobs.online
