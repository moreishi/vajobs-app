generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String?
  name             String?
  role             String    @default("guest")
  connects         Int       @default(50)
  lastConnectsReset DateTime?
  emailVerified    DateTime?
  image            String?
  accounts         Account[]
  sessions         Session[]
  jobPosts         JobPost[]
  sentMessages     Message[]
  applications     Application[] @relation("Applicant")
  profile          Profile?
  clientProfile    ClientProfile?
  notifications    Notification[]
  savedJobs        SavedJob[]
  connectTransactions ConnectTransaction[]
  reviewsGiven        Review[]               @relation("Reviewer")
  reviewsReceived     Review[]               @relation("Reviewee")
  talentEngagements   Engagement[]           @relation("TalentEngagements")
  clientEngagements   Engagement[]           @relation("ClientEngagements")
  contractsAsClient   Contract[]             @relation("ContractClient")
  contractsAsTalent   Contract[]             @relation("ContractTalent")
  sentInvoices        Invoice[]              @relation("InvoiceSender")
  receivedInvoices    Invoice[]              @relation("InvoiceRecipient")
  paymentOrders       PaymentOrder[]
  clientSubscriptions ClientSubscription[]
  vaSubscriptions     VaSubscription[]
  notificationPreferences NotificationPreference[]
  savedSearchAlerts       SavedSearchAlert[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model JobPost {
  id               String   @id @default(cuid())
  title            String
  description      String
  shortDescription String?
  location         String?
  type             String   @default("full-time")
  salaryRange      String?
  skills           String   @default("[]")
  status           String   @default("open")
  posterId         String
  posterName       String?
  poster           User     @relation(fields: [posterId], references: [id], onDelete: Cascade)
  applications     Application[]
  savedBy          SavedJob[]
  engagements      Engagement[]
  assessments      SkillAssessment[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SkillAssessment {
  id          String   @id @default(cuid())
  jobPostId   String
  clientId    String
  title       String
  description String?
  questions   String   @default("[]")
  passScore   Int?
  timeLimit   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobPost  JobPost             @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  attempts AssessmentAttempt[]

  @@index([jobPostId])
}

model AssessmentAttempt {
  id            String    @id @default(cuid())
  assessmentId  String
  applicantId   String
  applicationId String    @unique
  answers       String    @default("[]")
  score         Int?
  passed        Boolean?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  assessment  SkillAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  application Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([applicantId])
}

model Application {
  id              String   @id @default(cuid())
  jobPostId       String
  applicantId     String
  coverLetter     String?
  status          String   @default("pending")
  biddingConnects Int      @default(1)
  bidAmount       Float?
  bidType         String   @default("fixed")
  timeline        Int?
  approach        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  jobPost      JobPost             @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  applicant    User                @relation("Applicant", fields: [applicantId], references: [id], onDelete: Cascade)
  conversation Conversation?
  interview    Interview?
  review       Review?
  engagement   Engagement?
  assessmentAttempt AssessmentAttempt?

  @@unique([jobPostId, applicantId])
  @@index([applicantId])
  @@index([jobPostId])
}

model Conversation {
  id            String   @id @default(cuid())
  applicationId String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  messages    Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  attachmentUrl  String?
  attachmentName String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Interview {
  id            String   @id @default(cuid())
  applicationId String   @unique
  scheduledAt   DateTime
  duration      Int?
  meetingLink   String?
  notes         String?
  status        String   @default("scheduled")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  headline     String?
  bio          String?
  skills       String   @default("[]")
  hourlyRate   Int?
  experience   Int?
  availability String   @default("available")
  isPublic     Boolean  @default(true)
  verified     Boolean  @default(false)
  badges       String   @default("[]")
  resumeUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioItems PortfolioItem[]

  @@index([isPublic])
}

model PortfolioItem {
  id          String   @id @default(cuid())
  profileId   String
  title       String
  description String?
  url         String?
  imageUrl    String?
  type        String   @default("project")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String
  type   String
  email  Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobPostId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPost JobPost @relation(fields: [jobPostId], references: [id], onDelete: Cascade)

  @@unique([userId, jobPostId])
  @@index([userId])
}

model SavedSearchAlert {
  id         String   @id @default(cuid())
  userId     String
  type       String   @default("jobs")
  name       String
  filters    String   @default("{}")
  active     Boolean  @default(true)
  lastMatchedAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type, active])
}

model ConnectTransaction {
  id             String       @id @default(cuid())
  userId         String
  amount         Int
  type           String
  description    String?
  paymentOrderId String?      @unique
  createdAt      DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentOrder PaymentOrder? @relation(fields: [paymentOrderId], references: [id])

  @@index([userId])
}

model EmailLog {
  id         String   @id @default(cuid())
  userId     String?
  email      String
  type       String
  subject    String
  status     String   @default("sent")
  error      String?
  createdAt  DateTime @default(now())

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model PaymentSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model SubscriptionPlan {
  id               String   @id @default(cuid())
  name             String
  description      String?
  durationMonths   Int
  priceInCents     Int
  currency         String   @default("usd")
  connectsPerPeriod Int?
  badge            String?
  active           Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clientSubscriptions ClientSubscription[]
  paymentOrders        PaymentOrder[]

  @@index([active, sortOrder])
}

model ClientSubscription {
  id               String    @id @default(cuid())
  userId           String
  planId           String
  status           String    @default("active")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  autoRenew        Boolean   @default(true)
  cancelledAt      DateTime?
  paymentOrderId   String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])
  paymentOrder PaymentOrder?    @relation(fields: [paymentOrderId], references: [id])

  @@index([userId, status])
  @@index([currentPeriodEnd])
  @@index([status, autoRenew])
}

model PaymentOrder {
  id                String    @id @default(cuid())
  userId            String
  type              String    @default("connects")
  connectsAmount    Int?
  priceInCents      Int
  currency          String    @default("usd")
  provider          String
  providerSessionId String?
  providerOrderId   String?
  status            String    @default("pending")
  description       String?
  planId            String?
  invoiceId         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  completedAt       DateTime?

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectTransaction ConnectTransaction?
  clientSubscription ClientSubscription?
  plan               SubscriptionPlan?   @relation(fields: [planId], references: [id])
  invoice            Invoice?            @relation(fields: [invoiceId], references: [id])

  @@index([userId])
  @@index([providerSessionId])
  @@index([status])
  @@index([type, status])
  @@index([invoiceId])
}

model ClientProfile {
  id      String  @id @default(cuid())
  userId  String  @unique
  company String?
  title   String?
  bio     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id            String   @id @default(cuid())
  applicationId String   @unique
  reviewerId    String
  revieweeId    String
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewer    User        @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee    User        @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@index([revieweeId])
}

model Engagement {
  id            String    @id @default(cuid())
  applicationId String    @unique
  talentId      String
  clientId      String
  jobPostId     String
  status        String    @default("active")
  startDate     DateTime  @default(now())
  rate          Float?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  talent      User        @relation("TalentEngagements", fields: [talentId], references: [id], onDelete: Cascade)
  client      User        @relation("ClientEngagements", fields: [clientId], references: [id], onDelete: Cascade)
  jobPost     JobPost     @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  contract    Contract?

  @@index([talentId])
  @@index([clientId])
  @@index([jobPostId])
}

model Contract {
  id            String    @id @default(cuid())
  engagementId  String    @unique
  clientId      String
  talentId      String
  title         String
  terms         String
  rate          Float
  rateType      String    @default("fixed")
  startDate     DateTime
  endDate       DateTime?
  status        String    @default("draft")
  signedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  client     User       @relation("ContractClient", fields: [clientId], references: [id], onDelete: Cascade)
  talent     User       @relation("ContractTalent", fields: [talentId], references: [id], onDelete: Cascade)
  invoices   Invoice[]
  milestones Milestone[]

  @@index([clientId])
  @@index([talentId])
  @@index([engagementId])
}

model Milestone {
  id          String    @id @default(cuid())
  contractId  String
  title       String
  description String?
  amount      Float
  dueDate     DateTime?
  status      String    @default("pending")
  completedAt DateTime?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

model Invoice {
  id            String    @id @default(cuid())
  contractId    String
  engagementId  String
  fromId        String
  toId          String
  amount        Float
  currency      String    @default("USD")
  description   String?
  status        String    @default("pending")
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contract      Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  sender        User            @relation("InvoiceSender", fields: [fromId], references: [id], onDelete: Cascade)
  recipient     User            @relation("InvoiceRecipient", fields: [toId], references: [id], onDelete: Cascade)
  paymentOrders PaymentOrder[]

  @@index([contractId])
  @@index([fromId])
  @@index([toId])
  @@index([status])
}

model VaSubscriptionPlan {
  id            String   @id @default(cuid())
  name          String
  description   String?
  priceInCents  Int
  features      String   @default("[]")
  badge         String?
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vaSubscriptions VaSubscription[]

  @@index([active, sortOrder])
}

model VaSubscription {
  id        String    @id @default(cuid())
  userId    String
  planId    String
  status    String    @default("active")
  startDate DateTime  @default(now())
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan VaSubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([userId, status])
  @@index([planId])
}
