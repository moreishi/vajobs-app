generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String?
  name             String?
  role             String    @default("guest")
  connects         Int       @default(50)
  lastConnectsReset DateTime?
  emailVerified    DateTime?
  image            String?
  accounts         Account[]
  sessions         Session[]
  jobPosts         JobPost[]
  sentMessages     Message[]
  applications     Application[] @relation("Applicant")
  profile          Profile?
  clientProfile    ClientProfile?
  notifications    Notification[]
  savedJobs        SavedJob[]
  connectTransactions ConnectTransaction[]
  reviewsGiven        Review[]               @relation("Reviewer")
  reviewsReceived     Review[]               @relation("Reviewee")
  talentEngagements   Engagement[]           @relation("TalentEngagements")
  clientEngagements   Engagement[]           @relation("ClientEngagements")
  paymentOrders       PaymentOrder[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model JobPost {
  id               String   @id @default(cuid())
  title            String
  description      String
  shortDescription String?
  location         String?
  type             String   @default("full-time")
  salaryRange      String?
  skills           String   @default("[]")
  status           String   @default("open")
  posterId         String
  posterName       String?
  poster           User     @relation(fields: [posterId], references: [id], onDelete: Cascade)
  applications     Application[]
  savedBy          SavedJob[]
  engagements      Engagement[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Application {
  id              String   @id @default(cuid())
  jobPostId       String
  applicantId     String
  coverLetter     String?
  status          String   @default("pending")
  biddingConnects Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  jobPost      JobPost      @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  applicant    User         @relation("Applicant", fields: [applicantId], references: [id], onDelete: Cascade)
  conversation Conversation?
  interview    Interview?
  review       Review?
  engagement   Engagement?

  @@unique([jobPostId, applicantId])
  @@index([applicantId])
  @@index([jobPostId])
}

model Conversation {
  id            String   @id @default(cuid())
  applicationId String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  messages    Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  attachmentUrl  String?
  attachmentName String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Interview {
  id            String   @id @default(cuid())
  applicationId String   @unique
  scheduledAt   DateTime
  duration      Int?
  meetingLink   String?
  notes         String?
  status        String   @default("scheduled")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  headline     String?
  bio          String?
  skills       String   @default("[]")
  hourlyRate   Int?
  experience   Int?
  availability String   @default("available")
  isPublic     Boolean  @default(true)
  resumeUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isPublic])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobPostId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPost JobPost @relation(fields: [jobPostId], references: [id], onDelete: Cascade)

  @@unique([userId, jobPostId])
  @@index([userId])
}

model ConnectTransaction {
  id             String       @id @default(cuid())
  userId         String
  amount         Int
  type           String
  description    String?
  paymentOrderId String?      @unique
  createdAt      DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentOrder PaymentOrder? @relation(fields: [paymentOrderId], references: [id])

  @@index([userId])
}

model PaymentSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model PaymentOrder {
  id                String    @id @default(cuid())
  userId            String
  connectsAmount    Int
  priceInCents      Int
  currency          String    @default("usd")
  provider          String
  providerSessionId String?
  providerOrderId   String?
  status            String    @default("pending")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  completedAt       DateTime?

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectTransaction ConnectTransaction?

  @@index([userId])
  @@index([providerSessionId])
  @@index([status])
}

model ClientProfile {
  id      String  @id @default(cuid())
  userId  String  @unique
  company String?
  title   String?
  bio     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id            String   @id @default(cuid())
  applicationId String   @unique
  reviewerId    String
  revieweeId    String
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewer    User        @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee    User        @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@index([revieweeId])
}

model Engagement {
  id            String    @id @default(cuid())
  applicationId String    @unique
  talentId      String
  clientId      String
  jobPostId     String
  status        String    @default("active")
  startDate     DateTime  @default(now())
  rate          Float?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  talent      User        @relation("TalentEngagements", fields: [talentId], references: [id], onDelete: Cascade)
  client      User        @relation("ClientEngagements", fields: [clientId], references: [id], onDelete: Cascade)
  jobPost     JobPost     @relation(fields: [jobPostId], references: [id], onDelete: Cascade)

  @@index([talentId])
  @@index([clientId])
  @@index([jobPostId])
}
