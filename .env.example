# Database — SQLite is default, switch to Postgres in production
# SQLite (development):
DATABASE_URL="file:./dev.db"
# PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@host:5432/talent-hub?schema=public"
# PgBouncer (connection pooling — use with Prisma Accelerate or direct pool):
# DATABASE_URL="postgresql://user:password@host:6543/talent-hub?schema=public&pgbouncer=true&connection_limit=1"

# NextAuth — generate with: openssl rand -hex 32
AUTH_SECRET=your-secret-key-here

# Google OAuth (optional) — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# App URL — used for email links and callbacks
AUTH_URL=http://localhost:3000

# Resend (email) — https://resend.com/api-keys
RESEND_API_KEY=

# From address — use onboarding@resend.dev for sandbox testing, or your verified domain in production
EMAIL_FROM=onboarding@resend.dev
