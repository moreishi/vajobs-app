# Database -- PostgreSQL is required (Prisma schema uses postgresql provider)
# Local development (run Postgres via Docker: docker compose up db -d):
DATABASE_URL="postgresql://talent_hub:talent_hub@localhost:5432/talent_hub?schema=public"
# Production:
# DATABASE_URL="postgresql://user:password@host:5432/talent-hub?schema=public"
# PgBouncer (connection pooling):
# DATABASE_URL="postgresql://user:password@host:6543/talent-hub?schema=public&pgbouncer=true&connection_limit=1"

# PostgreSQL credentials (used by docker-compose.yml -- override to customize)
POSTGRES_USER=talent_hub
POSTGRES_PASSWORD=talent_hub
POSTGRES_HOST=localhost
POSTGRES_DB=talent_hub
PG_PORT=5432

# NextAuth -- generate with: openssl rand -hex 32
AUTH_SECRET=your-secret-key-here

# Google OAuth (optional) -- https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# App URL -- used for email links and callbacks
AUTH_URL=http://localhost:3000

# Sitemap base URL (used for sitemap.xml generation)
NEXT_PUBLIC_URL=http://localhost:3000

# Force seed in production (set to "true" on first Coolify deploy)
# In production: generates a random 48-char admin password, prints to logs,
# and emails it to admin@vajobs.online if RESEND_API_KEY + EMAIL_FROM are set.
# Test users and demo job posts are NOT created in production.
# FORCE_SEED=true

# Cron secret for subscription renewal endpoint
# CRON_SECRET=your-cron-secret

# Resend (email) -- https://resend.com/api-keys
RESEND_API_KEY=

# From address -- use onboarding@resend.dev for sandbox testing, or your verified domain in production
EMAIL_FROM=onboarding@resend.dev

# Stripe (optional) -- https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal (optional) -- https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_SANDBOX=true

# HitPay (optional) -- https://dashboard.hitpayapp.com/settings/api
HITPAY_API_KEY=
HITPAY_SALT=

# Xendit (optional) -- https://dashboard.xendit.co/settings/api-keys
XENDIT_SECRET_API_KEY=

# Maya (optional) -- https://dashboard.paymaya.com/developers
MAYA_PUBLIC_KEY=
MAYA_SECRET_KEY=
MAYA_SANDBOX=true

# S3-compatible storage (optional) -- for file uploads in production
# Set S3_BUCKET to enable S3 storage instead of local filesystem.
# Compatible with AWS S3, DigitalOcean Spaces, MinIO, etc.
# S3_BUCKET=my-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=https://my-bucket.sgp1.digitaloceanspaces.com

# Sentry (optional) -- https://sentry.io/settings/account/api/keys/
# SENTRY_DSN=https://key@oXXXXX.ingest.us.sentry.io/XXXXX
# NEXT_PUBLIC_SENTRY_DSN=https://key@oXXXXX.ingest.us.sentry.io/XXXXX
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
